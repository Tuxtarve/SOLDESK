          <mxGeometry x="410" y="60" width="290" height="175" as="geometry"/>
        </mxCell>

        <!-- Redis replication arrow -->
        <mxCell id="redis_repl" value="&lt;font style=&quot;font-size:9px&quot;&gt;Replication&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#C62828;strokeWidth=1.5;dashed=1;dashPattern=4 4;fontSize=9;fontColor=#C62828;endArrow=classic;endFill=1;" edge="1" source="redisp" target="redisr" parent="redisgrp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- OUTSIDE-VPC AWS SERVICES (right side)        -->
        <!-- ============================================ -->

        <!-- Divider line between VPC and outside services -->
        <mxCell id="divider_label" value="&lt;font style=&quot;font-size:10px;color:#78909C&quot;&gt;&lt;i&gt;AWS Managed Services (outside VPC)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=center;rotation=-90;" vertex="1" parent="aws">
          <mxGeometry x="1620" y="800" width="250" height="20" as="geometry"/>
        </mxCell>

        <!-- ECR -->
        <mxCell id="ecr" value="&lt;b&gt;Amazon ECR&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;4 Repositories&lt;br&gt;event-svc, reserv-svc,&lt;br&gt;worker-svc, frontend&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=1.5;fontSize=11;fontColor=#0D47A1;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1720" y="180" width="230" height="85" as="geometry"/>
        </mxCell>

        <!-- IAM / OIDC -->
        <mxCell id="iam" value="&lt;b&gt;IAM + OIDC&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;GitHub Actions Role&lt;br&gt;IRSA (ALB, Autoscaler, SQS)&lt;br&gt;OIDC Provider&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1.5;fontSize=11;fontColor=#F57F17;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="2000" y="180" width="220" height="85" as="geometry"/>
        </mxCell>

        <!-- S3 Frontend -->
        <mxCell id="s3f" value="&lt;b&gt;S3 Bucket&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ticketing-frontend-{acct}&lt;br&gt;Static Website (React/Nginx)&lt;br&gt;Public access blocked (OAC)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=11;fontColor=#4A148C;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1720" y="320" width="250" height="85" as="geometry"/>
        </mxCell>

        <!-- S3 Assets -->
        <mxCell id="s3a" value="&lt;b&gt;S3 Bucket&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ticketing-assets-{acct}&lt;br&gt;Versioned &amp;nbsp;|&amp;nbsp; Asset Storage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=11;fontColor=#4A148C;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1720" y="440" width="250" height="70" as="geometry"/>
        </mxCell>

        <!-- Cognito -->
        <mxCell id="cognito" value="&lt;b&gt;Amazon Cognito&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;User Pool + Web Client&lt;br&gt;Email Auth &amp;nbsp;|&amp;nbsp; OAuth 2.0 + OIDC&lt;br&gt;Token: 1h access, 7d refresh&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;strokeWidth=1.5;fontSize=11;fontColor=#004D40;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1720" y="570" width="250" height="85" as="geometry"/>
        </mxCell>

        <!-- Lambda -->
        <mxCell id="lambda" value="&lt;b&gt;Lambda&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Auto-Confirm&lt;br&gt;Python 3.12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=1.5;fontSize=11;fontColor=#BF360C;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="2020" y="580" width="140" height="65" as="geometry"/>
        </mxCell>

        <!-- SQS FIFO -->
        <mxCell id="sqs" value="&lt;b&gt;Amazon SQS FIFO&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ticketing-reservation.fifo&lt;br&gt;Visibility: 60s&lt;br&gt;Content Deduplication&lt;br&gt;MessageGroupId per seat group&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=11;fontColor=#1B5E20;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1720" y="720" width="260" height="100" as="geometry"/>
        </mxCell>

        <!-- SQS DLQ -->
        <mxCell id="sqsdlq" value="&lt;b&gt;SQS DLQ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(FIFO)&lt;br&gt;Max Receive: 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=1.5;fontSize=11;fontColor=#B71C1C;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="2030" y="730" width="150" height="70" as="geometry"/>
        </mxCell>

        <!-- CloudWatch -->
        <mxCell id="cw" value="&lt;b&gt;Amazon CloudWatch&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;RDS, SQS, Lambda Metrics&lt;br&gt;60s scrape via CW Exporter&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=1.5;fontSize=11;fontColor=#0D47A1;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1720" y="885" width="250" height="70" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- DATA FLOW EDGES                              -->
        <!-- ============================================ -->

        <!-- Users → CloudFront -->
        <mxCell id="e_users_cf" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;HTTPS&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7B1FA2;strokeWidth=2;fontSize=10;fontColor=#7B1FA2;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="users" target="cf" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CloudFront → S3 Frontend (static) -->
        <mxCell id="e_cf_s3" value="&lt;font style=&quot;font-size:9px&quot;&gt;Static Content&lt;br&gt;(OAC)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=9;fontColor=#7B1FA2;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="cf" target="s3f" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CloudFront → ALB (API) -->
        <mxCell id="e_cf_alb" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;/api/*&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1565C0;strokeWidth=2;fontSize=10;fontColor=#1565C0;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="cf" target="alb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- WAF ↔ CloudFront (attached) -->
        <mxCell id="e_waf_cf" value="&lt;font style=&quot;font-size:9px&quot;&gt;Filters&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#C62828;strokeWidth=2;fontSize=9;fontColor=#C62828;endArrow=classic;endFill=1;startArrow=classic;startFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="waf" target="cf" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ALB → event-svc -->
        <mxCell id="e_alb_evt" value="&lt;font style=&quot;font-size:9px&quot;&gt;/api/events&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1565C0;strokeWidth=2;fontSize=9;fontColor=#1565C0;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;exitX=0.25;exitY=1;exitDx=0;exitDy=0;" edge="1" source="alb" target="evtsvc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ALB → reserv-svc -->
        <mxCell id="e_alb_rsv" value="&lt;font style=&quot;font-size:9px&quot;&gt;/api/reservations&lt;br&gt;/api/payments&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1565C0;strokeWidth=2;fontSize=9;fontColor=#1565C0;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="alb" target="rsvsvc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- event-svc → Redis (cache) -->
        <mxCell id="e_evt_redis" value="&lt;font style=&quot;font-size:9px;color:#C62828&quot;&gt;Cache R/W&lt;br&gt;(30s/5s TTL)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;fontColor=#C62828;endArrow=classic;endFill=1;startArrow=classic;startFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="evtsvc" target="redisp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- event-svc → RDS Reader -->
        <mxCell id="e_evt_rdsr" value="&lt;font style=&quot;font-size:9px;color:#E65100&quot;&gt;SELECT&lt;br&gt;(cache miss)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E65100;strokeWidth=1.5;fontSize=9;fontColor=#E65100;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="evtsvc" target="rdsr" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- reserv-svc → Redis (lock) -->
        <mxCell id="e_rsv_redis" value="&lt;font style=&quot;font-size:9px;color:#C62828&quot;&gt;Distributed&lt;br&gt;Lock (NX)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;fontColor=#C62828;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="rsvsvc" target="redisp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- reserv-svc → RDS Writer -->
        <mxCell id="e_rsv_rdsw" value="&lt;font style=&quot;font-size:9px;color:#E65100&quot;&gt;R/W&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E65100;strokeWidth=1.5;fontSize=9;fontColor=#E65100;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="rsvsvc" target="rdsw" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- reserv-svc → SQS (enqueue) -->
        <mxCell id="e_rsv_sqs" value="&lt;font style=&quot;font-size:10px;color:#2E7D32&quot;&gt;&lt;b&gt;SendMessage&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2E7D32;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#2E7D32;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="rsvsvc" target="sqs" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SQS → worker-svc (poll) -->
        <mxCell id="e_sqs_wrk" value="&lt;font style=&quot;font-size:10px;color:#2E7D32&quot;&gt;&lt;b&gt;ReceiveMessage&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;(Long-poll 20s)&lt;/font&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2E7D32;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#2E7D32;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="sqs" target="wrksvc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- worker-svc → RDS Writer -->
        <mxCell id="e_wrk_rdsw" value="&lt;font style=&quot;font-size:9px;color:#E65100&quot;&gt;INSERT/UPDATE&lt;br&gt;(FOR UPDATE lock)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E65100;strokeWidth=1.5;fontSize=9;fontColor=#E65100;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="wrksvc" target="rdsw" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- worker-svc → Redis (unlock) -->
        <mxCell id="e_wrk_redis" value="&lt;font style=&quot;font-size:9px;color:#C62828&quot;&gt;DEL&lt;br&gt;(unlock)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;fontColor=#C62828;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="wrksvc" target="redisp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SQS → SQS DLQ -->
        <mxCell id="e_sqs_dlq" value="&lt;font style=&quot;font-size:9px;color:#C62828&quot;&gt;Failed ×3&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#C62828;strokeWidth=1.5;dashed=1;fontSize=9;fontColor=#C62828;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="sqs" target="sqsdlq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Lambda → Cognito (trigger) -->
        <mxCell id="e_lambda_cognito" value="&lt;font style=&quot;font-size:9px&quot;&gt;Pre Sign-up&lt;br&gt;Trigger&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#00695C;strokeWidth=1.5;fontSize=9;fontColor=#00695C;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="lambda" target="cognito" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- CI/CD EDGES                                  -->
        <!-- ============================================ -->

        <!-- GitHub → ECR -->
        <mxCell id="e_gh_ecr" value="&lt;font style=&quot;font-size:9px;color:#E65100&quot;&gt;Push&lt;br&gt;Images&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E65100;strokeWidth=1.5;dashed=1;dashPattern=5 5;fontSize=9;fontColor=#E65100;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="github" target="ecr" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- GitHub → S3 -->
        <mxCell id="e_gh_s3" value="&lt;font style=&quot;font-size:9px;color:#E65100&quot;&gt;Sync + Invalidate&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E65100;strokeWidth=1.5;dashed=1;dashPattern=5 5;fontSize=9;fontColor=#E65100;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="github" target="s3f" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Monitoring: Prometheus → CloudWatch -->
        <mxCell id="e_prom_cw" value="&lt;font style=&quot;font-size:8px;color:#546E7A&quot;&gt;Metrics (via Exporter)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#546E7A;strokeWidth=1;dashed=1;dashPattern=3 3;fontSize=8;fontColor=#546E7A;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;" edge="1" source="cwexp" target="cw" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- RESERVATION FLOW DESCRIPTION                 -->
        <!-- ============================================ -->
        <mxCell id="flow_box" value="&lt;b style=&quot;font-size:13px;color:#1565C0&quot;&gt;Reservation Data Flow&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#37474F&quot;&gt;&lt;b&gt;1.&lt;/b&gt; User → CloudFront → ALB → &lt;b&gt;reserv-svc&lt;/b&gt;&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; Acquire Redis distributed lock (NX, 600s TTL)&lt;br&gt;&lt;b&gt;3.&lt;/b&gt; Decrement Redis inventory (optimistic)&lt;br&gt;&lt;b&gt;4.&lt;/b&gt; Enqueue SQS FIFO message (MessageGroupId)&lt;br&gt;&lt;b&gt;5.&lt;/b&gt; Return &lt;b&gt;HTTP 202&lt;/b&gt; Pending (10-min expiry)&lt;br&gt;&lt;br&gt;&lt;b&gt;6.&lt;/b&gt; &lt;b&gt;worker-svc&lt;/b&gt; polls SQS (20s long-poll, batch 5)&lt;br&gt;&lt;b&gt;7.&lt;/b&gt; SELECT seats FOR UPDATE (row-level lock)&lt;br&gt;&lt;b&gt;8.&lt;/b&gt; INSERT reservation + reservation_seats&lt;br&gt;&lt;b&gt;9.&lt;/b&gt; UPDATE seat status → RESERVED&lt;br&gt;&lt;b&gt;10.&lt;/b&gt; DELETE Redis lock key&lt;br&gt;&lt;b&gt;11.&lt;/b&gt; ACK (DeleteMessage) from SQS&lt;br&gt;&lt;br&gt;&lt;b&gt;Payment:&lt;/b&gt; POST /api/payments (approved → CONFIRMED)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;strokeWidth=1.5;dashed=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=12;spacingRight=12;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1700" y="1030" width="380" height="370" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- CI/CD PIPELINE DESCRIPTION                   -->
        <!-- ============================================ -->
        <mxCell id="cicd_box" value="&lt;b style=&quot;font-size:13px;color:#E65100&quot;&gt;CI/CD Pipeline (GitHub Actions)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#37474F&quot;&gt;&lt;b&gt;Trigger:&lt;/b&gt; Push to master / Manual&lt;br&gt;&lt;b&gt;Auth:&lt;/b&gt; OIDC → IAM Role (no static keys)&lt;br&gt;&lt;br&gt;&lt;b&gt;1.&lt;/b&gt; Detect changed services (path filter)&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; Build Docker image (SHA + latest)&lt;br&gt;&lt;b&gt;3.&lt;/b&gt; Push to ECR&lt;br&gt;&lt;b&gt;4.&lt;/b&gt; kubectl set image (rolling update)&lt;br&gt;&lt;b&gt;5.&lt;/b&gt; Rollout status check (120s timeout)&lt;br&gt;&lt;br&gt;&lt;b&gt;Frontend:&lt;/b&gt;&lt;br&gt;&lt;b&gt;1.&lt;/b&gt; aws s3 sync --delete&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; CloudFront cache invalidation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;strokeWidth=1.5;dashed=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=12;spacingRight=12;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1700" y="1450" width="380" height="320" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- LEGEND                                       -->
        <!-- ============================================ -->
        <mxCell id="legend" value="&lt;b style=&quot;font-size:12px&quot;&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;font color=&quot;#1565C0&quot;&gt;━━━&lt;/font&gt; Synchronous Data Flow&lt;br&gt;&lt;font color=&quot;#2E7D32&quot;&gt;╌╌╌&lt;/font&gt; Async Queue Flow (SQS)&lt;br&gt;&lt;font color=&quot;#E65100&quot;&gt;┅┅┅&lt;/font&gt; CI/CD Pipeline&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;━━━&lt;/font&gt; Security / WAF&lt;br&gt;&lt;font color=&quot;#546E7A&quot;&gt;···&lt;/font&gt; Monitoring / Metrics&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#43A047&quot;&gt;██&lt;/font&gt; Public Subnet&lt;br&gt;&lt;font color=&quot;#FF8F00&quot;&gt;██&lt;/font&gt; Private Subnet&lt;br&gt;&lt;font color=&quot;#8E24AA&quot;&gt;██&lt;/font&gt; EKS Cluster&lt;br&gt;&lt;font color=&quot;#546E7A&quot;&gt;██&lt;/font&gt; Monitoring Stack&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;strokeWidth=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=12;fontSize=10;fontColor=#37474F;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="1700" y="1830" width="280" height="270" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- TECH STACK SUMMARY                           -->
        <!-- ============================================ -->
        <mxCell id="tech_box" value="&lt;b style=&quot;font-size:12px;color:#37474F&quot;&gt;Tech Stack Summary&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#546E7A&quot;&gt;&lt;b&gt;Backend:&lt;/b&gt; Python 3.12, FastAPI, uvicorn&lt;br&gt;&lt;b&gt;Frontend:&lt;/b&gt; React, Nginx 1.25-alpine&lt;br&gt;&lt;b&gt;IaC:&lt;/b&gt; Terraform ≥1.5, 11 modules&lt;br&gt;&lt;b&gt;Container:&lt;/b&gt; Docker (non-root, slim)&lt;br&gt;&lt;b&gt;Orchestration:&lt;/b&gt; Kubernetes (EKS 1.30)&lt;br&gt;&lt;b&gt;DB:&lt;/b&gt; MySQL 8.0 (aiomysql async)&lt;br&gt;&lt;b&gt;Cache:&lt;/b&gt; Redis 7.0 (redis.asyncio)&lt;br&gt;&lt;b&gt;Queue:&lt;/b&gt; SQS FIFO (boto3)&lt;br&gt;&lt;b&gt;Monitoring:&lt;/b&gt; Prometheus + Grafana&lt;br&gt;&lt;b&gt;Metrics:&lt;/b&gt; prometheus-client (Python)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;strokeWidth=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=12;fontSize=10;fontColor=#37474F;shadow=1;" vertex="1" parent="aws">
          <mxGeometry x="2040" y="1830" width="250" height="270" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
