        <!-- ============================================ -->
        <!-- RDS MySQL GROUP                              -->
        <!-- ============================================ -->
        <mxCell id="rdsgrp" value="&lt;b&gt;Amazon RDS&lt;/b&gt;&amp;nbsp; MySQL 8.0 &amp;nbsp;—&amp;nbsp; Multi-AZ &amp;nbsp;|&amp;nbsp; DB: ticketing &amp;nbsp;|&amp;nbsp; User: root" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=1.5;verticalAlign=top;fontStyle=0;fontSize=11;fontColor=#BF360C;container=1;collapsible=0;spacingTop=6;spacingLeft=12;" vertex="1" parent="privsub">
