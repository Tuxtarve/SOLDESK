        </mxCell>

        <!-- Security Group label for RDS -->
        <mxCell id="sg_rds" value="&lt;font style=&quot;font-size:8px;color:#BF360C&quot;&gt;🔒 DB_SG (prod-rds-sg) — Port 3306 from WAS_SG&lt;/font&gt;" style="text;html=1;align=right;" vertex="1" parent="rdsgrp">
          <mxGeometry x="350" y="25" width="350" height="15" as="geometry"/>
        </mxCell>

        <!-- RDS Writer -->
        <mxCell id="rdsw" value="&lt;b style=&quot;font-size:13px&quot;&gt;RDS Writer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;prod-ticketing-writer&lt;br&gt;db.t3.micro &amp;nbsp;|&amp;nbsp; 20GB gp3&lt;br&gt;Port: 3306&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;Tables: events, seats,&lt;br&gt;reservations, reservation_seats,&lt;br&gt;payments&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;fontSize=11;fontColor=#BF360C;shadow=1;verticalAlign=middle;" vertex="1" parent="rdsgrp">
          <mxGeometry x="40" y="60" width="290" height="175" as="geometry"/>
        </mxCell>

        <!-- RDS Reader -->
        <mxCell id="rdsr" value="&lt;b style=&quot;font-size:13px&quot;&gt;RDS Reader&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;prod-ticketing-reader&lt;br&gt;Read Replica&lt;br&gt;db.t3.micro &amp;nbsp;|&amp;nbsp; Port: 3306&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;event-svc reads from here&lt;br&gt;(read scaling)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;fontSize=11;fontColor=#BF360C;shadow=1;verticalAlign=middle;" vertex="1" parent="rdsgrp">
          <mxGeometry x="410" y="60" width="290" height="175" as="geometry"/>
        </mxCell>

        <!-- RDS replication arrow -->
        <mxCell id="rds_repl" value="&lt;font style=&quot;font-size:9px&quot;&gt;Replication&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E65100;strokeWidth=1.5;dashed=1;dashPattern=4 4;fontSize=9;fontColor=#E65100;endArrow=classic;endFill=1;" edge="1" source="rdsw" target="rdsr" parent="rdsgrp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DB Schema note -->
        <mxCell id="db_schema" value="&lt;font style=&quot;font-size:8px;color:#BF360C&quot;&gt;&lt;i&gt;Schema: events(UUID,status) → seats(UUID,event_id,status,price) → reservations(UUID,user_id,status,expires_at) → reservation_seats(M:M) → payments(UUID,status,method)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=left;whiteSpace=wrap;" vertex="1" parent="rdsgrp">
          <mxGeometry x="40" y="260" width="660" height="30" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- ELASTICACHE REDIS GROUP                      -->
        <!-- ============================================ -->
        <mxCell id="redisgrp" value="&lt;b&gt;Amazon ElastiCache&lt;/b&gt;&amp;nbsp; Redis 7.0 &amp;nbsp;—&amp;nbsp; 2-node Cluster &amp;nbsp;|&amp;nbsp; Auto-failover &amp;nbsp;|&amp;nbsp; Multi-AZ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=1.5;verticalAlign=top;fontStyle=0;fontSize=11;fontColor=#B71C1C;container=1;collapsible=0;spacingTop=6;spacingLeft=12;" vertex="1" parent="privsub">
