        <!-- ============================================ -->
        <mxCell id="eks" value="&lt;b&gt;Amazon EKS Cluster v1.30&lt;/b&gt;&amp;nbsp; (ticketing-eks) &amp;nbsp;—&amp;nbsp; 2× t3.small worker nodes &amp;nbsp;|&amp;nbsp; Namespace: ticketing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#8E24AA;strokeWidth=2;verticalAlign=top;fontStyle=0;fontSize=12;fontColor=#6A1B9A;container=1;collapsible=0;spacingTop=6;spacingLeft=12;" vertex="1" parent="pubsub">
          <mxGeometry x="80" y="95" width="1350" height="420" as="geometry"/>
        </mxCell>

        <!-- IRSA label -->
        <mxCell id="irsa_label" value="&lt;font style=&quot;font-size:9px;color:#6A1B9A&quot;&gt;&lt;i&gt;IRSA: ALB Controller, Cluster Autoscaler, SQS Access&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="eks">
          <mxGeometry x="20" y="28" width="350" height="18" as="geometry"/>
        </mxCell>

        <!-- event-svc -->
        <mxCell id="evtsvc" value="&lt;b style=&quot;font-size:13px&quot;&gt;event-svc&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;FastAPI :3000&lt;br&gt;2 replicas (HPA 2→8)&lt;br&gt;&lt;b&gt;GET&lt;/b&gt; /api/events&lt;br&gt;&lt;b&gt;GET&lt;/b&gt; /api/events/{id}/seats&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;&lt;i&gt;Redis Cache + RDS Reader&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=11;fontColor=#0D47A1;shadow=1;verticalAlign=middle;" vertex="1" parent="eks">
          <mxGeometry x="40" y="65" width="310" height="150" as="geometry"/>
        </mxCell>

        <!-- reserv-svc -->
        <mxCell id="rsvsvc" value="&lt;b style=&quot;font-size:13px&quot;&gt;reserv-svc&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;FastAPI :3001&lt;br&gt;2 replicas (HPA 2→8)&lt;br&gt;&lt;b&gt;POST&lt;/b&gt; /api/reservations&lt;br&gt;&lt;b&gt;POST&lt;/b&gt; /api/payments&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;&lt;i&gt;Redis Lock + SQS + RDS Writer&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=11;fontColor=#0D47A1;shadow=1;verticalAlign=middle;" vertex="1" parent="eks">
          <mxGeometry x="430" y="65" width="310" height="150" as="geometry"/>
        </mxCell>

        <!-- worker-svc -->
        <mxCell id="wrksvc" value="&lt;b style=&quot;font-size:13px&quot;&gt;worker-svc&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;FastAPI :3002&lt;br&gt;1 replica (Background)&lt;br&gt;SQS FIFO Consumer&lt;br&gt;Long-poll 20s, Batch 5&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;&lt;i&gt;RDS Writer + Redis Unlock&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=11;fontColor=#0D47A1;shadow=1;verticalAlign=middle;" vertex="1" parent="eks">
