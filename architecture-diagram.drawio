          <mxGeometry x="550" y="185" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- Prometheus scrape note -->
        <mxCell id="scrape_note" value="&lt;font style=&quot;font-size:8px;color:#546E7A&quot;&gt;&lt;i&gt;Prometheus scrapes: event-svc, reserv-svc, worker-svc /metrics (15s interval) + exporters&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="mon">
